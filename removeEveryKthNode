class Solution {
  removeEveryKthNode(head, k) {
    if (!head) return null; // return the new head (null if the list becomes empty)
    if (k === 1) return null;
      let count =1;
      let current=head;

      while (current!==null && current.next !==null) {
          count++;
          if (count===k) {
              current.next=current.next.next;
              count=0;
          } else{
              current=current.next;
          }
      }
      return head;
  }
}


